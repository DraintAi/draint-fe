# ── App identity ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=drain't

# ── WalletConnect ────────────────────────────────────────────────
# Get one at https://cloud.walletconnect.com (free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Default chain ────────────────────────────────────────────────
# 11155111=Ethereum Sepolia (primary, EIP-7702 testbed)
# 1=Ethereum Mainnet (for 1Shot demo)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# ── drain't backend ──────────────────────────────────────────────
NEXT_PUBLIC_DRAINT_API_URL=https://draint-be.vercel.app
# Local dev: http://localhost:3001

# ── Custom RPCs (overrides — defaults use publicnode, which has CORS) ──
# viem's default public RPC (eth.merkle.io) is rate-limited and missing
# Access-Control-Allow-Origin — must override or browser blocks.
NEXT_PUBLIC_ETHEREUM_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Deployed contract addresses ──────────────────────────────────
# Sepolia: live + verified
# https://sepolia.etherscan.io/address/0x2187d61279a8a54dc8907865959ef6cc8bebda14
NEXT_PUBLIC_ALLOWLIST_ENFORCER_SEPOLIA=0x2187D61279a8A54dc8907865959ef6cC8beBDa14
NEXT_PUBLIC_ALLOWLIST_ENFORCER_MAINNET=
NEXT_PUBLIC_DRAINT_AGENT_ADDRESS_SEPOLIA=
NEXT_PUBLIC_DRAINT_AGENT_ADDRESS_MAINNET=

# ── MM Smart Accounts Kit Delegator addresses (canonical) ────────
# Sepolia + Mainnet: same address (deterministic deploy)
NEXT_PUBLIC_MM_HYBRID_DELEGATOR=0x...
